#include<iostream>
using namespace std;

 // base class
class employee {
    public:
    int id;
    float salary;
    employee(int inpid){
        id = inpid;
        salary = 34.0 ;
    }
    employee(){}

};

/* derived class syntax
class {{derived-class-name}} : {{visibility mode}} {{base-class-name}}
{
    class members/methods/etc... 
} 
note :
1) default visibility mobe is private.
2) public visibility mode -: public member of base class become public member of derived class.
3) private visibility mode -: public member of base class become private member of derived class.
4) private memder are never inherited
*/

//creating a programer class derived from employee base class 
class programer : public employee{
    public:
    programer(int impid){
        id = impid;
    }
    int languagecode = 9;

    void getdata(){
        cout<<id<<endl;
    }

};

int main(){
    employee harry(1) , rohan(2);
    cout<<harry.salary<<endl;
    cout<<rohan.salary<<endl;
    programer skillf(10);
    cout<<skillf.languagecode<<endl;
    cout<<skillf.id<<endl;
    skillf.getdata();

    return 0;
}
