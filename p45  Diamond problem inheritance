#include<iostream>
using namespace std;

/* student --> test [done]
   student --> sports [done]
   test  -->  Results [done]
   sports --> Results [done]  */
class student{
    protected:
    int roll_no;

    public:
    void set_number(int a){
        roll_no=a;
    }
    void print_number(){
        cout<<"Your roll no. is "<<roll_no<<endl;
    }
};

class test : virtual public student {
    protected:
    float maths;
    float physics;

    public :
    void set_marks(float m1, float m2){
        maths = m1;
        physics = m2;
    }
    void print_marks(){
        cout<<"your result is: " <<endl
            << "maths : " <<maths <<endl
            << "physics : "<<physics <<endl;
    }
};

class sports : virtual public student {
    protected:
    float score;
    
    public :
    void set_score(float sc){
        score = sc ;
    }
    void print_score(){
        cout<<"Your PT score is "<<score<<endl;
    }
};

class result : public test , public sports{
    private :
    float total;
    public :
    void display(){
        total = maths + physics + score ; 
        print_number();
        print_marks();
        print_score();
        cout<<"Your total score is "<<total<<endl;
    }
};

int main(){
    result harry;
    harry.set_number(4200);
    harry.set_marks(78.9, 99.5);
    harry.set_score(9);
    harry.display();

    return 0;
}
